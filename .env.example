# ═══════════════════════════════════════════════
# BACKEND CONFIGURATION
# ═══════════════════════════════════════════════

# Flask/FastAPI Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=False

# Database (SQLite - никакой конфигурации не требуется!)
DATABASE_URL=sqlite:///./fraud_detection.db

# ═══════════════════════════════════════════════
# ML CONFIGURATION
# ═══════════════════════════════════════════════

# Model paths
MODEL_XGBOOST_PATH=data/models/xgboost_model.joblib
MODEL_RANDOMFOREST_PATH=data/models/randomforest_model.joblib
MODEL_LSTM_PATH=data/models/lstm_model.h5
MODEL_ISOLATION_FOREST_PATH=data/models/isolation_forest_model.joblib
MODEL_META_LEARNER_PATH=data/models/meta_learner.joblib

# Fraud score thresholds
FRAUD_THRESHOLD_APPROVED=0.4
FRAUD_THRESHOLD_REVIEW=0.7
FRAUD_THRESHOLD_BLOCKED=1.0

# ═══════════════════════════════════════════════
# AI CONFIGURATION (Groq API - COMPLETELY FREE!)
# ═══════════════════════════════════════════════

# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GENERATION_INTERVAL_SECONDS=10

# ═══════════════════════════════════════════════
# NETWORK & MULTI-NODE SETUP
# ═══════════════════════════════════════════════

# Main server (Laptop 1)
MAIN_SERVER_HOST=192.168.1.100
MAIN_SERVER_PORT=8000

# Client A (Laptop 2)
CLIENT_A_HOST=192.168.1.101
CLIENT_A_PORT=8001

# Client B (Laptop 3)
CLIENT_B_HOST=192.168.1.102
CLIENT_B_PORT=8002

# ═══════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/fraud_detection.log
